{
  "tests": [
    {
      "name": "Список номеров",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Проверка существующего номера",
      "method": "GET",
      "path": "/?phone=3456789",
      "expectedStatus": 200,
      "expectedBody": {"found": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Добавление отзыва без участника",
      "method": "POST",
      "path": "/",
      "body": {"phone": "+7 (900) 000-00-01", "rating": 4, "comment": "Тестовый отзыв", "author": "Тест", "tags": "Платит вовремя"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Отзыв от участника",
      "method": "POST",
      "path": "/",
      "body": {"phone": "+7 (900) 000-00-02", "rating": 5, "comment": "Первый", "author_phone": "+7 (900) 000-00-99"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Повторный отзыв на тот же номер запрещён",
      "method": "POST",
      "path": "/",
      "body": {"phone": "+7 (900) 000-00-02", "rating": 4, "comment": "Повтор", "author_phone": "+7 (900) 000-00-99"},
      "expectedStatus": 409,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Редактирование без участника запрещено",
      "method": "PUT",
      "path": "/",
      "body": {"id": 999999, "rating": 5, "comment": "Попытка правки"},
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    },
    {
      "name": "Удаление без участника запрещено",
      "method": "DELETE",
      "path": "/",
      "body": {"id": 999999},
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    },
    {
      "name": "Мои отзывы по телефону участника",
      "method": "GET",
      "path": "/?mine=%2B7%20(900)%20000-00-99",
      "expectedStatus": 200
    },
    {
      "name": "Удаление тестовых отзывов без прав запрещено",
      "method": "POST",
      "path": "/",
      "body": {"action": "delete_test", "author_phone": "+7 (900) 000-00-99"},
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    },
    {
      "name": "Удаление тестовых отзывов админом",
      "method": "POST",
      "path": "/",
      "body": {"action": "delete_test", "author_phone": "+79652000177"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}
{
  "tests": [
    {
      "name": "Получить сообщения",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"messages": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Отправить сообщение без входа (разрешено)",
      "method": "POST",
      "path": "/",
      "body": {"text": "Привет всем"},
      "expectedStatus": 200,
      "expectedBody": {"message": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Сообщение с именем участника",
      "method": "POST",
      "path": "/",
      "body": {"text": "Я участник", "user_name": "Иванов Иван Иванович"},
      "expectedStatus": 200,
      "expectedBody": {"message": {"user_name": "Иванов Иван Иванович"}},
      "bodyMatcher": "partial"
    }
  ]
}
{
  "tests": [
    {
      "name": "Получить сообщения",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Отправить сообщение без входа (разрешено)",
      "method": "POST",
      "path": "/",
      "body": {"text": "Привет всем", "phone": "9990001122"},
      "expectedStatus": 200
    },
    {
      "name": "Сообщение с именем участника",
      "method": "POST",
      "path": "/",
      "body": {"text": "Я участник", "user_name": "Иванов Иван Иванович", "phone": "9990001133"},
      "expectedStatus": 200
    },
    {
      "name": "Лёгкий режим с большим since возвращает unchanged",
      "method": "GET",
      "path": "/?since=999999999",
      "expectedStatus": 200
    },
    {
      "name": "Удаление без телефона отклоняется",
      "method": "DELETE",
      "path": "/",
      "body": {"message_id": 1},
      "expectedStatus": 400
    },
    {
      "name": "Подписка на push без данных отклоняется",
      "method": "POST",
      "path": "/",
      "body": {"action": "subscribe", "subscription": {}},
      "expectedStatus": 400
    }
  ]
}
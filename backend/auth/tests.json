{
  "tests": [
    {
      "name": "Регистрация нового пользователя",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "test_miks@example.com", "password": "test123", "name": "Тест"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Вход с неверным паролем",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_miks@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Проверка токена без авторизации",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
